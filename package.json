function mdRender(text){
  if(!text || !text.trim()) return '<p style="color:#9aaac5;font-style:italic">No content yet.</p>';
  return text
    .replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;')
    .replace(/^## (.+)$/gm,'<h2>$1</h2>')
    .replace(/^### (.+)$/gm,'<h3>$1</h3>')
    .replace(/\*\*(.+?)\*\*/g,'<strong>$1</strong>')
    .replace(/^Speaker note: (.+)$/gm,'<div class="snote">&#127908; $1</div>')
    .replace(/\*(.+?)\*/g,'<em>$1</em>')
    .replace(/^---+$/gm,'<hr>')
    .replace(/^[-] (.+)$/gm,'<li>$1</li>')
    .replace(/^(\d+)\. (.+)$/gm,'<li>$2</li>')
    .replace(/

/g,'<p></p>')
    .replace(/
/g,'<br>');
}

render();
